# ============================================================================
# SIEM Homelab — Environment Template
# ============================================================================
# Copy this to .env and fill in your own values:
#   cp .env.example .env
# ============================================================================

COMPOSE_PROJECT_NAME=siem-homelab
SIEM_NETWORK=siem-net
HOST_INTERFACE=enp2s0

INDEXER_USERNAME=admin
INDEXER_PASSWORD=CHANGE_ME
INDEXER_JAVA_OPTS=-Xms1g -Xmx1g

WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=CHANGE_ME
WAZUH_MANAGER_HOSTNAME=wazuh-manager
WAZUH_CLUSTER_KEY=CHANGE_ME

DASHBOARD_USERNAME=kibanaserver
DASHBOARD_PASSWORD=CHANGE_ME

SPLUNK_PASSWORD=CHANGE_ME
SPLUNK_START_ARGS=--accept-license
SPLUNK_HEC_TOKEN=CHANGE_ME

THEHIVE_SECRET=CHANGE_ME
THEHIVE_ADMIN_PASSWORD=CHANGE_ME

MISP_ADMIN_EMAIL=admin@siem.local
MISP_ADMIN_PASSPHRASE=CHANGE_ME
MISP_BASE_URL=https://localhost/misp

NGINX_SSL_CERT=./nginx/certs/server.crt
NGINX_SSL_KEY=./nginx/certs/server.key

ELASTIC_MEMORY=1g
